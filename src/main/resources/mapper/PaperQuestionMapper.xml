<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.onik.eduspring.mapper.PaperQuestionMapper">

    <!--自动组成试卷-->
    <insert id="insert">
        INSERT INTO paper_question(paper_id, question_id, score, sort)
        VALUES
        <foreach collection="paperQuestions" item="pq" separator=",">
            (#{pq.paperId}, #{pq.questionId}, #{pq.score}, #{pq.sort})
        </foreach>
    </insert>
</mapper>